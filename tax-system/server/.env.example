# ── Server Configuration ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────
# Local development:
MONGODB_URI=mongodb://localhost:27017/tax_system
# Production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/tax_system?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────
# Thay bằng chuỗi ngẫu nhiên dài ít nhất 32 ký tự trong production!
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────
# Development: localhost:3000 được tự động allow
# Production: liệt kê các origin được phép (cách nhau bởi dấu phẩy)
# ALLOWED_ORIGINS=https://taxvn.vercel.app,https://www.taxvn.com
